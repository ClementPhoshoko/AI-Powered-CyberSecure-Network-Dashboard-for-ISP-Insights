# Server Configuration
PORT=5000
NODE_ENV=development
# Set to true when using HTTPS with a custom domain
USE_HTTPS=false

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Configuration (optional, fallback to rule-based if not set)
GEMINI_API_KEY=your_gemini_api_key
# Gemini model to use (default: gemini-2.5-flash). Change when a model is
# overloaded. Examples: gemini-2.0-flash, gemini-2.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# OTP Configuration
OTP_SECRET=your_otp_hmac_secret
ALLOWED_ORIGINS=http://localhost:5173

# Cloudflare Turnstile (bot protection for public forms)
# Secret key — server-side only, never expose to the client.
# Get it from the Cloudflare dashboard > Turnstile > your site.
# If unset: verification is skipped in development and blocked in production.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# EmailJS (server-side email delivery for OTP)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_VERIFY_ID=your_verify_template_id
EMAILJS_TEMPLATE_RESET_ID=your_reset_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Required for server-side API access — get from EmailJS dashboard > Account > API Keys
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
