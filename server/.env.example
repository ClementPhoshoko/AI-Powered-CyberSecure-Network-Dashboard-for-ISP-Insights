# Server Configuration
PORT=5000
NODE_ENV=development
# Set to true when using HTTPS with a custom domain
USE_HTTPS=false

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI Configuration (optional, fallback to rule-based if not set)
GEMINI_API_KEY=your_gemini_api_key

# OTP Configuration
OTP_SECRET=your_otp_hmac_secret
ALLOWED_ORIGINS=http://localhost:5173

# EmailJS (server-side email delivery for OTP)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_TEMPLATE_ID=your_emailjs_template_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
# Optional but recommended for server-side: get from EmailJS dashboard > Account > API Keys
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
